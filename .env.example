# Copy this file to .env and fill in your values.
# NEVER commit .env — it's in .gitignore.

# Supabase (https://supabase.com → Settings → API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anthropic (https://console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-...

# ntfy.sh — pick a hard-to-guess topic name (this is your "password")
# Install the ntfy app on your phone and subscribe to this topic
NTFY_TOPIC=ifiok-jobs-changeme-abc123

# Resend (https://resend.com → API Keys) — powers the email digest (digest.py)
RESEND_API_KEY=re_...
RESEND_FROM=alerts@yourdomain.com

# Where to send email digests
ALERT_EMAIL=simeonchere@gmail.com
